<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pavithra Kilari | Portfolio</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
scroll-behavior:smooth;
}

body{
background:#0f172a;
color:white;
overflow-x:hidden;
}

/* Scroll Bar */

::-webkit-scrollbar{
width:8px;
}

::-webkit-scrollbar-thumb{
background:#38bdf8;
border-radius:10px;
}

/* Navigation */

nav{
position:fixed;
top:0;
left:0;
width:100%;
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 8%;
background:rgba(15,23,42,.85);
backdrop-filter:blur(15px);
z-index:999;
}

.logo{
font-size:28px;
font-weight:700;
color:#38bdf8;
letter-spacing:1px;
}

nav ul{
display:flex;
gap:30px;
list-style:none;
}

nav ul li a{
text-decoration:none;
color:white;
font-weight:500;
transition:.3s;
}

nav ul li a:hover{
color:#38bdf8;
}

.themeBtn{
padding:10px 20px;
border:none;
background:#38bdf8;
color:white;
border-radius:30px;
cursor:pointer;
font-weight:600;
transition:.4s;
}

.themeBtn:hover{
transform:scale(1.08);
}

/* Hero Section */

.hero{
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:120px 8%;
gap:80px;
}

.heroImage img{
width:320px;
height:320px;
border-radius:50%;
object-fit:cover;
border:6px solid #38bdf8;
box-shadow:0 0 35px #38bdf8;
animation:float 4s ease-in-out infinite;
}

@keyframes float{

0%{
transform:translateY(0px);
}

50%{
transform:translateY(-20px);
}

100%{
transform:translateY(0px);
}

}

.heroText h3{
font-size:28px;
font-weight:500;
}

.heroText h1{
font-size:60px;
margin:10px 0;
color:#38bdf8;
}

.heroText h2{
font-size:34px;
margin-bottom:20px;
}

.heroText p{
font-size:17px;
line-height:30px;
color:#d1d5db;
max-width:600px;
}

.highlight{
color:#38bdf8;
font-weight:600;
}

.buttons{
margin-top:35px;
display:flex;
gap:20px;
}

.btn{
padding:14px 34px;
background:#38bdf8;
border:none;
border-radius:35px;
color:white;
font-size:16px;
cursor:pointer;
transition:.4s;
text-decoration:none;
}

.btn:hover{
transform:translateY(-5px);
box-shadow:0 0 20px #38bdf8;
}

.btn2{
background:transparent;
border:2px solid #38bdf8;
}

.btn2:hover{
background:#38bdf8;
}

/* Animated Background */

.bgCircle{
position:fixed;
border-radius:50%;
filter:blur(100px);
z-index:-1;
animation:move 15s infinite alternate;
}

.c1{
width:250px;
height:250px;
background:#00d4ff;
top:10%;
left:-5%;
}

.c2{
width:300px;
height:300px;
background:#9333ea;
bottom:-5%;
right:-5%;
}

@keyframes move{

from{
transform:translateY(-20px);
}

to{
transform:translateY(30px);
}

}

/* Section */

section{
padding:100px 10%;
}

.title{
font-size:40px;
text-align:center;
margin-bottom:60px;
color:#38bdf8;
position:relative;
}

.title::after{
content:'';
position:absolute;
left:50%;
bottom:-10px;
transform:translateX(-50%);
width:80px;
height:4px;
background:#38bdf8;
border-radius:20px;
}

/* About */

.about{
display:grid;
grid-template-columns:1fr 1fr;
gap:60px;
align-items:center;
}

.card{
background:rgba(255,255,255,.05);
padding:35px;
border-radius:20px;
backdrop-filter:blur(20px);
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 20px rgba(56,189,248,.3);
}

.card h3{
margin-bottom:20px;
color:#38bdf8;
}

.card p{
line-height:30px;
color:#d1d5db;
}

